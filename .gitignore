# ── Claudette2 .gitignore ──
# Inverted model: ignore everything, whitelist framework.
# Child projects (their own git repos) are invisible by default.

# Ignore everything
*

# ── Root-level framework files ──
!/*.py
!/*.md
!/.gitignore

# ── Framework directories (fully tracked) ──
!/.codex/
!/.codex/**
!/.templates/
!/.templates/**

# ── State directory (structure only, see .state/.gitignore) ──
!/.state/
!/.state/**

# ── Testing group (shipped with platform, git-tracked) ──
!/Testing/
!/Testing/**

# ── db-backup child project (git-tracked) ──
!/db-backup/
!/db-backup/**

# ── Generated (never track) ──
.claude/

# ── Underscore-prefixed (invisible by convention, never track) ──
_*/
_*

# ── OS / editor artifacts (belt-and-suspenders) ──
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ── Secrets (never track) ──
.env*
*.key
*.pem
