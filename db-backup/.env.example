# db-backup profiles
# ────────────────────────────────────────────────────────────────────
# A "profile" is the UPPERCASE_SNAKE name between DB_ and _URL.
# The slash command takes profile names in lowercase-hyphenated form:
#   /db-backup supabase-prod   →   reads DB_SUPABASE_PROD_URL
#
# Required per profile:  DB_<PROFILE>_URL
# Optional per profile:  DB_<PROFILE>_RESTORE_IMAGE    (Tier 2 Docker image)
#                        DB_<PROFILE>_SCHEMAS          (CSV, default: public)
# ────────────────────────────────────────────────────────────────────

# ── Supabase example ──
# IMPORTANT: use port 5432 (direct) — port 6543 is pgBouncer and will NOT work with pg_dump.
# Supabase uses custom extensions (pgsodium, pgjwt, etc.) so Tier 2 needs the matching image.
DB_SUPABASE_PROD_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DB_SUPABASE_PROD_RESTORE_IMAGE=supabase/postgres:15.1.0.147
DB_SUPABASE_PROD_SCHEMAS=public

# ── Generic Postgres example (Neon, Railway, Render, RDS, etc.) ──
# DB_NEON_MAIN_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Default restore image postgres:<source-major> works for vanilla Postgres hosts.
# DB_NEON_MAIN_SCHEMAS=public,app
