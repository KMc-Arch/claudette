#!/usr/bin/env bash
# Thin wrapper around cboot.py — "run cboot here" (bash / WSL).
#
# Resolves the claudette apex, then dispatches by where you are:
#   - at the apex root -> full boot           ( python cboot.py "$@" )
#   - inside a child   -> refresh that child  ( python cboot.py --project <root> "$@" )
#
# Apex resolution — bedrock is the CLAUDE.md that declares `apex-root: true`:
#   1. If $CLAUDETTE_HOME is set, it WINS. It must be a valid apex (a directory
#      whose CLAUDE.md declares apex-root: true, containing cboot.py) or we fail
#      loudly — never a silent fall-back to walk-up. Use it when claudette and
#      your projects live in different trees (decohered).
#   2. Otherwise walk up from CWD to the directory whose CLAUDE.md declares
#      apex-root: true. Hard error if none is found.
#   In both cases the apex must contain cboot.py, else hard error.
#
# "child" = nearest ancestor (at or above CWD) whose CLAUDE.md declares
# `root: true` / `apex-root: true` — i.e. the context root `^`.
# An explicit --project / -p anywhere in the args is passed through unchanged.
set -euo pipefail

norm() { if command -v realpath >/dev/null 2>&1; then realpath -m "$1"; else printf '%s' "$1"; fi; }

has_apex_root() {  # $1 = dir; succeeds if its CLAUDE.md declares apex-root: true
  [ -f "$1/CLAUDE.md" ] && grep -Eq '^apex-root:[[:space:]]*true' "$1/CLAUDE.md"
}

# Walk up from CWD to the apex (dir whose CLAUDE.md declares apex-root: true).
find_apex_by_marker() {
  local d="$PWD" parent
  while :; do
    has_apex_root "$d" && { printf '%s' "$d"; return 0; }
    [ "$d" = "/" ] && break
    parent="$(dirname "$d")"
    [ "$parent" = "$d" ] && break
    d="$parent"
  done
  return 1
}

# Nearest root:true / apex-root:true ancestor at or above CWD (the context root ^).
find_root() {
  local apex="$1" d="$PWD" parent
  while :; do
    if [ -f "$d/CLAUDE.md" ] && grep -Eq '^(root|apex-root):[[:space:]]*true' "$d/CLAUDE.md"; then
      printf '%s' "$d"; return 0
    fi
    [ "$d" = "$apex" ] && break
    [ "$d" = "/" ] && break
    parent="$(dirname "$d")"
    [ "$parent" = "$d" ] && break
    d="$parent"
  done
  return 1
}

if [ -n "${CLAUDETTE_HOME:-}" ]; then
  # Explicit apex wins — validate it, never silently fall back to walk-up.
  apex="$(norm "$CLAUDETTE_HOME")"
  [ -d "$apex" ] || { echo "cboot: CLAUDETTE_HOME is not a directory: $apex" >&2; exit 1; }
  has_apex_root "$apex" || { echo "cboot: CLAUDETTE_HOME is not an apex (no CLAUDE.md with 'apex-root: true'): $apex" >&2; exit 1; }
else
  apex="$(find_apex_by_marker)" || {
    echo "cboot: apex not found (no CLAUDE.md with 'apex-root: true' above CWD). Set CLAUDETTE_HOME." >&2
    exit 1
  }
  apex="$(norm "$apex")"
fi

[ -f "$apex/cboot.py" ] || { echo "cboot: apex at $apex has no cboot.py (malformed install)." >&2; exit 1; }

PY="$(command -v python || command -v python3 || true)"
[ -n "$PY" ] || { echo "cboot: no python interpreter on PATH (tried python, python3)." >&2; exit 1; }

# An explicit --project always wins — pass everything straight through.
for a in "$@"; do
  case "$a" in
    --project|--project=*|-p) exec "$PY" "$apex/cboot.py" "$@" ;;
  esac
done

root="$(find_root "$apex")" && root="$(norm "$root")" || root="$(norm "$PWD")"

if [ "$root" = "$apex" ]; then
  exec "$PY" "$apex/cboot.py" "$@"                     # at apex: full boot
else
  exec "$PY" "$apex/cboot.py" --project "$root" "$@"   # in child: refresh this project
fi
