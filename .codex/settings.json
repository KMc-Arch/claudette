{
  "$comment": "Codex-authoritative Claude Code settings. Materialized to .claude/settings.json at boot by codex-register.",
  "plansDirectory": ".state/plans",
  "effortLevel": "xhigh",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(ls:*)",
      "Bash(mkdir -p:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(git remote remove:*)",
      "Bash(gh issue:*)",
      "Bash(gh api:*)",
      "Bash(gh release:*)"
    ]
  },
  "modules": {
    "statusline": ".codex/implicit/01-infrastructural/01b-materialization/statusline/settings.json"
  }
}
